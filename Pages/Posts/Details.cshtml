@page
@model blogsite.Pages.Posts.DetailsModel

@{
    ViewData["Title"] = Model.Post.Title;
}

<h1>@Model.Post.Title</h1>

<div class="row">
    <div class="col-md-8">
        <p>@Model.Post.Content</p>
    </div>
    
    <div class="col-md-4">
        <h3 class="text-center">Related posts</h3>
        <ul>
            @foreach (var related in Model.RelatedPosts)
            {
                <li>
                    <a asp-page="./Details" asp-route-id="@related.Id">@related.Title</a>
                </li>
            }
        </ul>
    </div>
</div>
<div>
    <a asp-page="./Edit" asp-route-id="@Model.Post.Id">Edit</a> |
    <a asp-page="./Delete" asp-route-id="@Model.Post.Id">Delete</a> |
    <a asp-page="/Index">Back to List</a>
</div>
